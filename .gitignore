# Python
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Node / Next.js
node_modules/
apps/web/.next/
apps/web/out/
npm-debug.log*

# Local data (never commit the user's portfolio / DB)
# NOTE: leading slash anchors this to the repo root only — an un-anchored "data/"
# also matches the source package packages/lucore/lucore/data/ and silently drops it.
/data/
*.db
*.sqlite
*.parquet

# Personal reference material (Futu screenshots + exported watchlists = holdings)
/reference/

# Service supervisor PID files + logs (scripts/start-web.sh)
*.pid
*.log

# Env / secrets
.env
.env.local
*.local

# OS / editor
.DS_Store
.idea/
.vscode/

# Editor swap files
*.swp

# TS incremental build cache
*.tsbuildinfo

# Playwright E2E artifacts
apps/web/playwright-report/
apps/web/test-results/
apps/web/blob-report/
