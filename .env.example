# limit-up (LU) configuration. Copy to .env and edit. All keys are optional —
# LU runs with zero config and zero AI cost out of the box.

# --- LLM provider: claude_code (default, free via Max plan) | glm | anthropic ---
LU_LLM_PROVIDER=claude_code
# LU_CLAUDE_BIN=claude
# LU_CLAUDE_MODEL=
# LU_GLM_API_KEY=
# LU_ANTHROPIC_API_KEY=

# --- Data sources (yfinance + SEC EDGAR need no key) ---
LU_SEC_USER_AGENT=limit-up LU research you@example.com
# LU_FINNHUB_API_KEY=

# --- Markets ---
LU_ENABLE_HK=true
LU_ENABLE_CN=true

# --- Storage (defaults to ./data) ---
# LU_DATA_DIR=./data
